{
  "manifest_version": 3,
  "name": "Milestone Timer",
  "description": "Track progress toward any age milestone from your new tab page.",
  "version": "0.6.1",
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "action": {
    "default_title": "Milestone Timer",
    "default_popup": "popup.html"
  },
  "permissions": ["storage"],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  }
}
